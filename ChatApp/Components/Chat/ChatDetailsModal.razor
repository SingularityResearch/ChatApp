@using ChatApp.Models

@if (IsOpen && Conversation != null)
{
    <div class="modal-overlay" @onclick="OnClose">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h5 class="mb-0">Details</h5>
                <button type="button" class="btn-close" @onclick="OnClose"></button>
            </div>
            <div class="modal-body">
                @if (Conversation.IsGroup)
                {
                    <h6 class="text-muted small mb-2">CHAT NAME</h6>
                    <div class="input-group mb-4">
                        <input type="text" class="form-control" placeholder="Group Name" @bind="editTitle" />
                        <button class="btn btn-outline-primary" type="button" @onclick="HandleRename">Save</button>
                    </div>
                }

                <h6 class="text-muted small mb-2">PARTICIPANTS</h6>
                <ul class="list-group list-group-flush">
                    @foreach (var uid in Conversation.ParticipantIds)
                    {
                        var name = AllUsers.TryGetValue(uid, out var u) ? u.UserName : (uid == CurrentUserId ? "You" :
                        "Unknown");
                        var isOnline = OnlineUsers.ContainsKey(uid);

                        <li class="list-group-item d-flex align-items-center p-2 bg-transparent border-0">
                            <span class="status-dot @(isOnline || uid == CurrentUserId ? "online" : "offline")"></span>
                            <span class="flex-grow-1">@name</span>
                            @if (uid == CurrentUserId)
                            {
                                <span class="badge bg-light text-dark">You</span>
                            }
                        </li>
                    }
                </ul>
            </div>
            <div class="modal-footer d-flex flex-column gap-2">
                <button class="btn btn-primary w-100" @onclick="OnAddPeople">
                    <i class="bi bi-person-plus-fill me-2"></i>Add People
                </button>
                <button class="btn btn-outline-danger w-100"
                @onclick="() => OnLeaveChat.InvokeAsync(Conversation.ConversationId)">
                    <i class="bi bi-box-arrow-right me-2"></i>Leave Chat
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public ConversationViewModel? Conversation { get; set; }
    [Parameter] public Dictionary<string, UserDto> AllUsers { get; set; } = new();
    [Parameter] public Dictionary<string, string> OnlineUsers { get; set; } = new();
    [Parameter] public string CurrentUserId { get; set; } = string.Empty;
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnAddPeople { get; set; }
    [Parameter] public EventCallback<int> OnLeaveChat { get; set; }
    [Parameter] public EventCallback<string> OnRenameChat { get; set; }

    private string editTitle = "";
    private bool wasOpen;

    protected override void OnParametersSet()
    {
        if (IsOpen && !wasOpen)
        {
            editTitle = Conversation?.Title ?? "";
        }
        wasOpen = IsOpen;
    }

    private async Task HandleRename()
    {
        if (Conversation != null)
        {
            await OnRenameChat.InvokeAsync(editTitle);
        }
    }
}
