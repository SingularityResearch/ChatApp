@page "/admin"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Admin Dashboard</PageTitle>

<div class="container mt-4">
    <h1>Admin Dashboard</h1>
    <p class="lead">Manage your application settings and users.</p>

    <div class="row mt-4">
        <!-- Manage Roles Card -->
        <div class="col-md-4 mb-4">
            <div class="card bg-dark text-white border-secondary h-100 shadow-sm admin-card">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-people-fill me-2 text-primary"></i>User Roles</h5>
                    <p class="card-text">Manage user roles and assignments (Groups).</p>
                    <a href="admin/roles" class="btn btn-primary w-100 mt-2">Manage Roles</a>
                </div>
            </div>
        </div>

        <!-- Banner Management Card -->
        <div class="col-md-4 mb-4">
            <div class="card bg-dark text-white border-secondary h-100 shadow-sm admin-card">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-layout-text-window me-2 text-primary"></i>Program Banners</h5>
                    <p class="card-text">Configure headers securely by user role context.</p>
                    <a href="admin/banners" class="btn btn-primary w-100 mt-2">Manage Banners</a>
                </div>
            </div>
        </div>

        <!-- Reporting Card -->
        <div class="col-md-4 mb-4">
            <div class="card bg-dark text-white border-secondary h-100 shadow-sm admin-card">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-graph-up me-2 text-primary"></i>User Activity</h5>
                    <p class="card-text">View chat statistics and user activity reports.</p>
                    <a href="admin/reporting" class="btn btn-primary w-100 mt-2">View Report</a>
                </div>
            </div>
        </div>

        <!-- User Roles Card -->
        <div class="col-md-4 mb-4">
            <div class="card bg-dark text-white border-secondary h-100 shadow-sm admin-card">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-person-lines-fill me-2 text-primary"></i>Roles Mapping</h5>
                    <p class="card-text">View a complete list of all users and their assigned roles.</p>
                    <a href="admin/user-roles" class="btn btn-primary w-100 mt-2">View Map</a>
                </div>
            </div>
        </div>
    </div>
</div>
