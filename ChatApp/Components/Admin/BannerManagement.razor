@page "/admin/banners"
@using ChatApp.Data
@using ChatApp.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@inject BannerService BannerService
@inject RoleManager<IdentityRole> RoleManager
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<PageTitle>Manage Program Banners</PageTitle>

<div class="container-fluid py-4 h-100 overflow-auto">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h3 class="text-white m-0">Manage Program Banners</h3>
                <p class="summary-text text-muted mb-0">Customize banner appearance for each program role.</p>
            </div>
            <a href="admin" class="btn btn-outline-light"><i class="bi bi-arrow-left pe-2"></i>Back to Admin</a>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-light mt-3">Loading banners...</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var role in availableRoles)
            {
                var banner = GetBannerForRole(role.Name!);
                <div class="col-md-6 mb-4">
                    <div class="card bg-dark border-secondary h-100 shadow">
                        <div
                            class="card-header bg-secondary bg-opacity-25 border-secondary d-flex justify-content-between align-items-center">
                            <h5 class="mb-0 text-white"><i class="bi bi-collection-fill me-2 text-primary"></i>@role.Name</h5>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" role="switch" id="active-@role.Name"
                                @bind="banner.IsActive">
                                <label class="form-check-label text-light" for="active-@role.Name">Active</label>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label for="text-@role.Name" class="form-label text-light">Banner Text</label>
                                <input type="text" class="form-control bg-dark text-white border-secondary" id="text-@role.Name"
                                @bind="banner.BannerText" placeholder="Enter banner text...">
                            </div>
                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label for="bg-@role.Name" class="form-label text-light">Background Color</label>
                                    <input type="color" class="form-control form-control-color w-100 bg-dark border-secondary"
                                        id="bg-@role.Name" @bind="banner.BackgroundColor" title="Choose background color">
                                </div>
                                <div class="col-md-6">
                                    <label for="fg-@role.Name" class="form-label text-light">Text Color</label>
                                    <input type="color" class="form-control form-control-color w-100 bg-dark border-secondary"
                                        id="fg-@role.Name" @bind="banner.TextColor" title="Choose text color">
                                </div>
                            </div>

                            <hr class="border-secondary my-4" />
                            <h6 class="text-light mb-2">Live Preview:</h6>
                            <div class="rounded p-2 text-center"
                                style="background-color: @banner.BackgroundColor; color: @banner.TextColor; border: 1px solid rgba(255,255,255,0.1);">
                                @(string.IsNullOrWhiteSpace(banner.BannerText) ? "Banner Text Preview" : banner.BannerText)
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-secondary text-end">
                            <button class="btn btn-primary" @onclick="() => PromptSaveBanner(banner)">
                                <i class="bi bi-save me-2"></i>Save Banner
                            </button>
                        </div>
                    </div>
                </div>
            }

            @if (!availableRoles.Any())
            {
                <div class="col-12">
                    <div class="alert alert-info bg-dark border-info text-info">
                        <i class="bi bi-info-circle-fill me-2"></i> No roles found. Please create roles first in Role
                        Management.
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showConfirmModal && bannerToSave != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-white border-secondary">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title">Confirm Save</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CancelSave"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to save the banner configuration for <strong>@bannerToSave.RoleName</strong>?</p>
                    
                    <div class="row g-3 my-3">
                        <div class="col-12">
                            <h6 class="text-muted small mb-1">Current Banner:</h6>
                            @if (originalBannerToSave != null && originalBannerToSave.IsActive)
                            {
                                <div class="rounded p-2 text-center"
                                    style="background-color: @originalBannerToSave.BackgroundColor; color: @originalBannerToSave.TextColor; border: 1px solid rgba(255,255,255,0.1);">
                                    @(string.IsNullOrWhiteSpace(originalBannerToSave.BannerText) ? "Banner Text Preview" : originalBannerToSave.BannerText)
                                </div>
                            }
                            else
                            {
                                <div class="rounded p-2 text-center text-muted bg-dark border border-secondary" style="border-style: dashed !important;">
                                    <em>Inactive / No Banner</em>
                                </div>
                            }
                        </div>
                        
                        <div class="col-12 text-center">
                            <i class="bi bi-arrow-down fs-4 text-muted"></i>
                        </div>

                        <div class="col-12">
                            <h6 class="text-primary small mb-1">New Banner:</h6>
                            @if (bannerToSave.IsActive)
                            {
                                <div class="rounded p-2 text-center"
                                    style="background-color: @bannerToSave.BackgroundColor; color: @bannerToSave.TextColor; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 0 10px rgba(96, 205, 255, 0.2);">
                                    @(string.IsNullOrWhiteSpace(bannerToSave.BannerText) ? "Banner Text Preview" : bannerToSave.BannerText)
                                </div>
                            }
                            else
                            {
                                <div class="rounded p-2 text-center text-muted bg-dark border border-secondary" style="border-style: dashed !important;">
                                    <em>Inactive / No Banner</em>
                                </div>
                            }
                        </div>
                    </div>

                    <p class="text-muted small mb-0">This will immediately update the banner for all users with this role when they next load the application.</p>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-secondary" @onclick="CancelSave">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmSaveAsync">Yes, Save Changes</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private List<ProgramBanner> banners = new();
    private List<IdentityRole> availableRoles = new();
    private Dictionary<string, ProgramBanner> roleBanners = new();
    
    private bool showConfirmModal = false;
    private ProgramBanner? bannerToSave = null;
    private ProgramBanner? originalBannerToSave = null;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            availableRoles = RoleManager.Roles.OrderBy(r => r.Name).ToList();
            banners = await BannerService.GetAllBannersAsync();

            foreach (var role in availableRoles)
            {
                var existing = banners.FirstOrDefault(b => b.RoleName == role.Name);
                if (existing != null)
                {
                    roleBanners[role.Name!] = existing;
                }
                else
                {
                    roleBanners[role.Name!] = new ProgramBanner
                        {
                            RoleName = role.Name!,
                            BannerText = $"Welcome to {role.Name}",
                            BackgroundColor = "#101010",
                            TextColor = "#ffffff",
                            IsActive = false
                        };
                }
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private ProgramBanner GetBannerForRole(string roleName)
    {
        return roleBanners.TryGetValue(roleName, out var banner) ? banner : new ProgramBanner { RoleName = roleName };
    }

    private async Task PromptSaveBanner(ProgramBanner banner)
    {
        bannerToSave = banner;
        // Fetch fresh from DB to show 'Before' state, since in-memory banners list is mutated by the UI
        var currentDbBanners = await BannerService.GetAllBannersAsync();
        var existingTokens = currentDbBanners.FirstOrDefault(b => b.RoleName == banner.RoleName);
        originalBannerToSave = existingTokens != null ? new ProgramBanner 
        {
            Id = existingTokens.Id,
            RoleName = existingTokens.RoleName,
            BannerText = existingTokens.BannerText,
            BackgroundColor = existingTokens.BackgroundColor,
            TextColor = existingTokens.TextColor,
            IsActive = existingTokens.IsActive
        } : new ProgramBanner { RoleName = banner.RoleName, IsActive = false };
        
        showConfirmModal = true;
    }

    private void CancelSave()
    {
        // Revert the actively bound memory object back to the unedited database state
        if (bannerToSave != null && originalBannerToSave != null)
        {
            bannerToSave.BannerText = originalBannerToSave.BannerText;
            bannerToSave.BackgroundColor = originalBannerToSave.BackgroundColor;
            bannerToSave.TextColor = originalBannerToSave.TextColor;
            bannerToSave.IsActive = originalBannerToSave.IsActive;
        }

        showConfirmModal = false;
        bannerToSave = null;
        originalBannerToSave = null;
    }

    private async Task ConfirmSaveAsync()
    {
        if (bannerToSave != null)
        {
            await BannerService.UpdateBannerAsync(bannerToSave);
            showConfirmModal = false;
            bannerToSave = null;
            
            // Re-fetch banners to ensure state is completely in sync with DB
            banners = await BannerService.GetAllBannersAsync();
        }
    }
}
