@page "/chat"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@using ChatApp.Services
@using Microsoft.AspNetCore.Authorization
@using ChatApp.Models
@using ChatApp.Components.Chat
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ChatStateService ChatState
@inject IServiceScopeFactory ScopeFactory
@inject IHttpContextAccessor HttpContextAccessor
@inject IChatMessageService ChatMessageService
@inject IJSRuntime JSRuntime
@inject BannerStateService BannerState
@using Microsoft.AspNetCore.Identity
@inject UserManager<ChatApp.Data.ApplicationUser> UserManager
@attribute [Authorize]
@implements IAsyncDisposable

<PageTitle>Chat</PageTitle>

<div class="chat-container">
    <!-- Sidebar -->
    <ConversationList Conversations="Conversations" SelectedConversation="SelectedConversation"
        CurrentUserId="@currentUserId" OnlineUsers="OnlineUsers" AllUsers="AllUsers"
        OnConversationSelected="OnConversationSelected" OnStartNewChat="OnStartNewChat" />

    <!-- Main Chat Area -->
    <div class="chat-main-area">
        @if (IsNewChatMode)
        {
                <NewChatView AllUsers="AllUsers" OnlineUsers="OnlineUsers" SelectedUsers="NewChatSelectedUsers"
                    IsAddingParticipants="IsAddingParticipants" IsConnected="IsConnected" OnToggleUser="OnToggleNewChatUser"
                    OnStart="OnStartChat" OnFileUpload="OnFileUpload" />
        }
        else if (SelectedConversation != null)
        {
                <ActiveChatView @ref="activeChatView" Conversation="SelectedConversation" IsConnected="IsConnected"
                    OnToggleDetails="ToggleDetails" OnSend="HandleSend" OnFileUpload="OnFileUpload" OnStartEdit="StartEdit"
                    OnDelete="DeleteMessage" OnSaveEdit="SaveEdit" OnCancelEdit="CancelEdit" OnReply="HandleReply"
                    OnToggleReaction="HandleToggleReaction" />

                <ChatDetailsModal IsOpen="IsDetailsOpen" Conversation="SelectedConversation" AllUsers="AllUsers"
                    OnlineUsers="OnlineUsers" CurrentUserId="@currentUserId" OnClose="ToggleDetails"
                    OnAddPeople="AddUserToCurrentChat" OnLeaveChat="HandleLeaveChat" OnRenameChat="HandleRenameChat" />

                <DeleteConfirmationModal IsOpen="IsDeleteConfirmOpen" Message="MessageToDelete" OnConfirm="ConfirmDelete"
                    OnCancel="CancelDelete" />
        }
        else
        {
                <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                    <p class="fs-4">Select a conversation or start a new one.</p>
                </div>
        }
    </div>
</div>

@if (IsNotificationVisible)
{
        <div class="toast-notification">
            <div class="d-flex align-items-center justify-content-between">
                <span>@NotificationMessage</span>
                <button class="btn-close btn-close-white ms-3" @onclick="CloseNotification"></button>
            </div>
        </div>
}

<style>
    /* Global Toast */
    .toast-notification {
        position: fixed;
        top: 20px;
        right: 20px;
        background-color: var(--accent-dark);
        color: white;
        padding: 12px 20px;
        border-radius: 8px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
        z-index: 2000;
        min-width: 250px;
        animation: slideIn 0.3s ease-out;
        cursor: pointer;
    }

    @@keyframes slideIn {
        from {
            transform: translateX(100%);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    /* Layout */
    .chat-container {
        display: flex;
        height: 100%;
        overflow: hidden;
    }

    .chat-main-area {
        flex: 1;
        display: flex;
        flex-direction: column;
        background-color: var(--mica-bg);
        min-width: 0;
        min-height: 0;
    }

    /* Global Status Dot (Used by multiple components) */
    .status-dot {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        margin-right: 6px;
    }

    .status-dot.online {
        background-color: #28a745;
        box-shadow: 0 0 4px #28a745;
    }

    .status-dot.offline {
        background-color: #dc3545;
        opacity: 0.6;
    }

    /* Modal Styles - Global */
    .modal-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
        backdrop-filter: blur(2px);
    }

    .modal-card {
        background-color: var(--mica-bg);
        border: 1px solid var(--card-border);
        border-radius: 12px;
        width: 350px;
        max-width: 90%;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .modal-header {
        padding: 15px;
        border-bottom: 1px solid var(--card-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: var(--mica-alt-bg);
    }

    .modal-body {
        max-height: 400px;
        overflow-y: auto;
        padding: 10px;
    }

    .modal-footer {
        padding: 15px;
        border-top: 1px solid var(--card-border);
        background-color: var(--mica-alt-bg);
        text-align: center;
    }
</style>

@code {
    // State
    private List<ConversationViewModel> Conversations = new List<ConversationViewModel>();
    private ConversationViewModel? SelectedConversation;
    private bool IsNewChatMode = false;
    private bool IsDetailsOpen = false;
    private bool IsAddingParticipants = false;
    private bool _shouldScrollToBottom = false;

    // Delete Modal State
    private bool IsDeleteConfirmOpen = false;
    private ChatMessage? MessageToDelete;

    private Dictionary<string, string> OnlineUsers = new Dictionary<string, string>();
    private Dictionary<string, UserDto> AllUsers = new Dictionary<string, UserDto>(); // UserId -> UserDto
    private HashSet<string> NewChatSelectedUsers = new HashSet<string>();

    private string? currentUserId;
    private string? currentUserName;
    private List<string> currentUserRoles = new();

    // Setup Safe File Extension Whitelist
    private readonly string[] _allowedExtensions = { ".jpg", ".jpeg", ".png", ".gif", ".webp", ".pdf", ".txt", ".docx",
".xlsx", ".csv" };
    private bool IsConnected => _hubConnection?.State == HubConnectionState.Connected;
    private HubConnection? _hubConnection;

    /// <summary>
    /// Executes after the component has rendered. Used to scroll the chat view down if there are new messages.
    /// </summary>
    /// <param name="firstRender">True if this is the first time the component has rendered.</param>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldScrollToBottom)
        {
            _shouldScrollToBottom = false;
            await Task.Delay(100);
            await JSRuntime.InvokeVoidAsync("scrollToBottom", "chatScrollView");
        }
    }

    /// <summary>
    /// Initializes the chat component, fetches user data, connects to SignalR, and loads initial conversation history.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            currentUserName = user.Identity.Name;

            currentUserRoles = user.Claims
                .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role || c.Type == "role")
                .Select(c => c.Value)
                .ToList();

            if (currentUserId != null && currentUserName != null)
            {
                await LoadData();
            }
        }

        ChatState.OnChange += HandleStateChange;

        UpdateOnlineUsers();

        var cookies = HttpContextAccessor.HttpContext?.Request.Headers.Cookie.ToString();

        _hubConnection = new HubConnectionBuilder()
        .WithUrl(Navigation.ToAbsoluteUri("/chathub"), options =>
        {
            if (!string.IsNullOrEmpty(cookies))
            {
                options.Headers.Add("Cookie", cookies);
            }
        })
        .WithAutomaticReconnect()
        .Build();

        _hubConnection.On<int, string, string, string, DateTime, string?, List<string>?, int>("ReceiveMessage", HandleMessageReceived);
        _hubConnection.On<int, string>("MessageEdited", HandleMessageEdited);
        _hubConnection.On<int>("MessageDeleted", HandleMessageDeleted);
        _hubConnection.On<int, string, string, string>("ReactionAdded", HandleReactionAdded);
        _hubConnection.On<int, string, string>("ReactionRemoved", HandleReactionRemoved);
        _hubConnection.On<int, string>("UserLeftConversation", HandleUserLeftConversation);
        _hubConnection.On<int, string>("ConversationTitleUpdated", HandleConversationTitleUpdated);

        await _hubConnection.StartAsync();
    }

    /// <summary>
    /// Disposes of the SignalR hub connection and unregisters state change events when the component is destroyed.
    /// </summary>
    public async ValueTask DisposeAsync()
    {
        ChatState.OnChange -= HandleStateChange;

        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
        }

        if (currentUserId != null)
        {
            BannerState.ClearActiveRoles(currentUserId);
        }
    }

    /// <summary>
    /// Handles updates to the global chat state (e.g. online users) and forces a UI refresh.
    /// </summary>
    private void HandleStateChange()
    {
        UpdateOnlineUsers();
        InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Updates the local dictionary of online users by fetching it from the ChatState service.
    /// </summary>
    private void UpdateOnlineUsers()
    {
        OnlineUsers = ChatState.GetOnlineUsers()
        .Where(u => u.Key != currentUserId)
        .ToDictionary(k => k.Key, v => v.Value);
    }

    /// <summary>
    /// SignalR handler that updates a specific message's content after an edit.
    /// </summary>
    /// <param name="messageId">The ID of the edited message.</param>
    /// <param name="newContent">The new text content.</param>
    private void HandleMessageEdited(int messageId, string newContent)
    {
        InvokeAsync(() =>
        {
            foreach (var conv in Conversations)
            {
                var msg = conv.Messages.FirstOrDefault(m => m.Id == messageId);
                if (msg != null)
                {
                    msg.Message = newContent;
                }
            }
            StateHasChanged();
        });
    }

    /// <summary>
    /// SignalR handler that removes a deleted message from the UI.
    /// </summary>
    /// <param name="messageId">The ID of the deleted message.</param>
    private void HandleMessageDeleted(int messageId)
    {
        InvokeAsync(() =>
        {
            foreach (var conv in Conversations)
            {
                var msg = conv.Messages.FirstOrDefault(m => m.Id == messageId);
                if (msg != null)
                {
                    conv.Messages.Remove(msg);
                }
            }
            StateHasChanged();
        });
    }

    /// <summary>
    /// SignalR handler that removes a participant from a conversation when they leave.
    /// </summary>
    /// <param name="conversationId">The ID of the conversation.</param>
    /// <param name="userId">The ID of the user who left.</param>
    private void HandleUserLeftConversation(int conversationId, string userId)
    {
        InvokeAsync(() =>
        {
            var conv = Conversations.FirstOrDefault(c => c.ConversationId == conversationId);
            if (conv != null)
            {
                conv.ParticipantIds.Remove(userId);
                conv.DisplayName = GenerateDisplayNameFromMap(conv.ParticipantIds.ToHashSet(), AllUsers);
                
                if (string.Equals(userId, currentUserId, StringComparison.OrdinalIgnoreCase))
                {
                    Conversations.Remove(conv);
                    if (SelectedConversation?.ConversationId == conversationId)
                    {
                        SelectedConversation = null;
                        UpdateBannerForCurrentChat();
                    }
                }
                
                Conversations = Conversations.ToList(); // Force Blazor to detect array change
                StateHasChanged();
            }
        });
    }

    /// <summary>
    /// SignalR handler that updates a conversation's display title when it is renamed.
    /// </summary>
    /// <param name="conversationId">The ID of the conversation.</param>
    /// <param name="newTitle">The newly assigned title.</param>
    private void HandleConversationTitleUpdated(int conversationId, string newTitle)
    {
        Console.WriteLine($"[Chat.razor] HandleConversationTitleUpdated called. ID: {conversationId}, NewTitle: {newTitle}");
        InvokeAsync(() =>
        {
            var conv = Conversations.FirstOrDefault(c => c.ConversationId == conversationId);
            if (conv != null)
            {
                Console.WriteLine($"[Chat.razor] Found conversation. Updating title and calling ToList.");
                conv.Title = newTitle;
                Conversations = Conversations.ToList(); // Force Blazor to detect array change
                StateHasChanged();
            }
            else
            {
                Console.WriteLine($"[Chat.razor] Conversation {conversationId} NOT FOUND in current Conversations list! Count: {Conversations.Count}");
            }
        });
    }

    /// <summary>
    /// Initiates a conversation rename request by sending it to the SignalR hub.
    /// </summary>
    /// <param name="newTitle">The requested new title for the chat.</param>
    private async Task HandleRenameChat(string newTitle)
    {
        if (_hubConnection != null && SelectedConversation != null && !string.IsNullOrWhiteSpace(newTitle))
        {
            await _hubConnection.SendAsync("UpdateConversationTitle", SelectedConversation.ConversationId, newTitle);
        }
    }

    /// <summary>
    /// SignalR handler that adds a user's reaction emoji to a message.
    /// </summary>
    /// <param name="messageId">The message ID.</param>
    /// <param name="userId">The ID of the reacting user.</param>
    /// <param name="userName">The display name of the reacting user.</param>
    /// <param name="emoji">The emoji string character.</param>
    private void HandleReactionAdded(int messageId, string userId, string userName, string emoji)
    {
        InvokeAsync(() =>
        {
            foreach (var conv in Conversations)
            {
                var msg = conv.Messages.FirstOrDefault(m => m.Id == messageId);
                if (msg != null)
                {
                    msg.Reactions.Add(new MessageReactionDto { Emoji = emoji, UserId = userId, UserName = userName });
                    StateHasChanged();
                    break;
                }
            }
        });
    }

    /// <summary>
    /// SignalR handler that removes a specific user's reaction from a message.
    /// </summary>
    /// <param name="messageId">The message ID.</param>
    /// <param name="userId">The user ID whose reaction is being removed.</param>
    /// <param name="emoji">The emoji string character being removed.</param>
    private void HandleReactionRemoved(int messageId, string userId, string emoji)
    {
        InvokeAsync(() =>
        {
            foreach (var conv in Conversations)
            {
                var msg = conv.Messages.FirstOrDefault(m => m.Id == messageId);
                if (msg != null)
                {
                    var existing = msg.Reactions.FirstOrDefault(r => r.UserId == userId && r.Emoji == emoji);
                    if (existing != null)
                    {
                        msg.Reactions.Remove(existing);
                        StateHasChanged();
                        break;
                    }
                }
            }
        });
    }

    /// <summary>
    /// Fetches all allowed users based on Role visibility rules, retrieves the current user's conversation history, 
    /// and hydrates view models.
    /// </summary>
    private async Task LoadData()
    {
        if (currentUserId == null) return;

        // Filter users based on Roles
        var visibleUsersList = await ChatState.GetVisibleUsersAsync(currentUserId);
        AllUsers = visibleUsersList.ToDictionary(u => u.Id, u => u);

        // Fetch history using the new Service method
        var history = await ChatMessageService.GetUserConversationsAsync(currentUserId);

        // Fetch missing usernames for senders/reactors
        var missingUserIds = history.SelectMany(c => c.Participants).Select(p => p.UserId)
            .Concat(history.SelectMany(c => c.Messages).SelectMany(m => m.Reactions).Select(r => r.UserId))
            .Concat(history.SelectMany(c => c.Messages).Select(m => m.SenderId))
            .Where(id => id != null && id != currentUserId && !AllUsers.ContainsKey(id))
            .Distinct()
            .ToList();

        var extraUsersNames = new Dictionary<string, string>();
        if (currentUserId != null && currentUserName != null)
        {
            extraUsersNames[currentUserId] = currentUserName;
        }

        foreach (var uid in missingUserIds)
        {
            if (uid == null) continue;
            var user = await UserManager.FindByIdAsync(uid);
            extraUsersNames[uid] = user?.UserName ?? "Unknown User";
        }

        Conversations.Clear();
        Console.WriteLine($"[Chat.razor] LoadData: Fetched {history.Count} conversations from DB.");

        foreach (var h in history)
        {
            var activeParticipants = h.Participants.Where(p => !p.HasLeft).Select(p => p.UserId).ToHashSet();

            var conversation = new ConversationViewModel
            {
                ConversationId = h.Id,
                Title = h.Title,
                ParticipantIds = activeParticipants.ToList(),
                DisplayName = GenerateDisplayNameFromMap(activeParticipants, AllUsers)
            };

            foreach (var m in h.Messages)
            {
                conversation.Messages.Add(new ChatMessage
                {
                    Id = m.Id,
                    User = AllUsers.TryGetValue(m.SenderId, out var u) ? u.UserName : (extraUsersNames.TryGetValue(m.SenderId, out var euName) ? euName : "Unknown User"),
                    Message = m.Message,
                    Timestamp = m.Timestamp,
                    AttachmentUrl = m.AttachmentUrl,
                    IsMine = m.SenderId == currentUserId,
                    SenderId = m.SenderId,
                    Reactions = m.Reactions.Select(r =>
                    {
                        string reactionUserName = "User";
                        if (AllUsers.TryGetValue(r.UserId, out var ru))
                            reactionUserName = ru.UserName;
                        else if (extraUsersNames.TryGetValue(r.UserId, out var euReacName))
                            reactionUserName = euReacName;
                        return new MessageReactionDto
                        {
                            Emoji = r.Emoji,
                            UserId = r.UserId,
                            UserName = reactionUserName
                        };
                    }).ToList()
                });
            }
            Conversations.Add(conversation);
        }

        if (SelectedConversation == null)
        {
            SelectedConversation = Conversations.OrderByDescending(c => c.LastActivity).FirstOrDefault();
        }

        if (SelectedConversation != null)
        {
            _shouldScrollToBottom = true;
            UpdateBannerForCurrentChat();
        }
    }

    /// <summary>
    /// Generates a unique string key to identify a conversation based on its participants.
    /// </summary>
    /// <param name="userIds">The list of participant UserIDs.</param>
    /// <returns>A sorted, pipe-delimited string of UserIDs.</returns>
    private string GetConversationKey(IEnumerable<string> userIds)
    {
        var sorted = userIds.OrderBy(u => u).ToList();
        return string.Join("|", sorted);
    }

    /// <summary>
    /// Creates a human-readable display name for a conversation (e.g., "Alice + 2 others").
    /// </summary>
    /// <param name="participantIds">The set of UserIDs in the chat.</param>
    /// <param name="userMap">A dictionary mapping UserIDs to User data transfer objects.</param>
    /// <returns>A formatted display string.</returns>
    private string GenerateDisplayNameFromMap(HashSet<string> participantIds, Dictionary<string, UserDto> userMap)
    {
        var others = participantIds.Where(u => u != currentUserId).ToList();

        if (others.Count == 0) return "Just You";

        // Get the first user's name
        var firstUid = others[0];
        string firstName = userMap.TryGetValue(firstUid, out var u) && !string.IsNullOrEmpty(u.UserName)
        ? u.UserName
        : firstUid.Substring(0, 8);

        if (others.Count == 1)
        {
            return firstName;
        }
        else
        {
            return $"{firstName} + {others.Count - 1} others";
        }
    }

    /// <summary>
    /// SignalR handler that receives an incoming chat message and updates the local UI.
    /// </summary>
    /// <param name="conversationId">The ID of the conversation.</param>
    /// <param name="senderId">The UserID of the message sender.</param>
    /// <param name="senderName">The display name of the message sender.</param>
    /// <param name="message">The text content of the message.</param>
    /// <param name="timestamp">The time the message was sent.</param>
    /// <param name="attachmentUrl">An optional URL for a file attachment.</param>
    /// <param name="participantIds">A list of UserIDs participating in the conversation.</param>
    /// <param name="messageId">The database ID of the created message.</param>
    private void HandleMessageReceived(int conversationId, string senderId, string senderName, string message, DateTime timestamp, string? attachmentUrl, List<string>? participantIds, int messageId)
    {
        if (currentUserId == null) return;

        // Restriction: Ignore messages from non-visible users (unless it's me)
        if (senderId != currentUserId && !AllUsers.ContainsKey(senderId)) return;

        var conversation = Conversations.FirstOrDefault(c => c.ConversationId == conversationId);

        if (conversation == null)
        {
            var participants = participantIds?.ToHashSet() ?? new HashSet<string>();
            if (!participants.Contains(senderId)) participants.Add(senderId);

            conversation = new ConversationViewModel
                {
                    ConversationId = conversationId,
                    ParticipantIds = participants.ToList(),
                    DisplayName = GenerateDisplayNameFromMap(participants, AllUsers)
                };

            Conversations.Add(conversation);
        }

        var msg = new ChatMessage
            {
                Id = messageId,
                User = senderName ?? senderId,
                Message = message,
                Timestamp = timestamp,
                AttachmentUrl = attachmentUrl,
                IsMine = senderId == currentUserId,
                SenderId = senderId,
                Reactions = new List<MessageReactionDto>()
            };

        conversation.Messages.Add(msg);

        InvokeAsync(async () =>
        {
            StateHasChanged();

            if (senderId != currentUserId)
            {
                bool isLookingAtIt = SelectedConversation != null && SelectedConversation.ConversationId == conversationId;

                if (!isLookingAtIt)
                {
                    ShowNotification($"New message from {senderName ?? "User"}", conversation!.DisplayName);
                }
                else
                {
                    // Delay slightly to ensure UI has rendered the message
                    await Task.Delay(50);
                    await JSRuntime.InvokeVoidAsync("scrollToBottom", "chatScrollView");
                }
            }
            else
            {
                // Message from me (e.g. from another tab/device)
                await Task.Delay(50);
                await JSRuntime.InvokeVoidAsync("scrollToBottom", "chatScrollView");
            }
        });
    }

    // Notification State
    private bool IsNotificationVisible = false;
    private string NotificationMessage = string.Empty;
    private Guid CurrentNotificationId;

    /// <summary>
    /// Displays a temporary toast notification when a new message arrives in a non-active chat.
    /// </summary>
    /// <param name="user">The name of the user who sent the message.</param>
    /// <param name="context">The name of the conversation.</param>
    private void ShowNotification(string user, string context)
    {
        NotificationMessage = $"{user} in {context}";
        IsNotificationVisible = true;
        var notifId = Guid.NewGuid();
        CurrentNotificationId = notifId;
        StateHasChanged();

        _ = Task.Delay(5000).ContinueWith(t =>
        {
            InvokeAsync(() =>
    {
        if (IsNotificationVisible && CurrentNotificationId == notifId)
        {
            IsNotificationVisible = false;
            StateHasChanged();
        }
    });
        });
    }

    /// <summary>
    /// Closes the currently visible toast notification.
    /// </summary>
    private void CloseNotification()
    {
        IsNotificationVisible = false;
    }

    // Actions
    /// <summary>
    /// Event handler for when a user selects a conversation from the sidebar list.
    /// </summary>
    /// <param name="c">The selected conversation view model.</param>
    private async Task OnConversationSelected(ConversationViewModel c)
    {
        SelectedConversation = c;
        IsNewChatMode = false;
        IsAddingParticipants = false;

        UpdateBannerForCurrentChat();

        await Task.Delay(50);
        await JSRuntime.InvokeVoidAsync("scrollToBottom", "chatScrollView");
    }

    /// <summary>
    /// Calculates the intersection of programmatic roles among participants and updates the BannerState.
    /// </summary>
    /// <param name="participantIds">The UserIDs of the conversation participants.</param>
    private void UpdateBannerForParticipants(IEnumerable<string>? participantIds)
    {
        if (participantIds == null || currentUserId == null)
        {
            if (currentUserId != null) BannerState.ClearActiveRoles(currentUserId);
            return;
        }

        var otherParticipants = participantIds.Where(id => id != currentUserId).ToList();

        if (!otherParticipants.Any())
        {
            BannerState.ClearActiveRoles(currentUserId);
            return;
        }

        // We'll intersect roles with everyone in the chat
        var commonRoles = new HashSet<string>(currentUserRoles);

        foreach (var pId in otherParticipants)
        {
            if (AllUsers.TryGetValue(pId, out var participant))
            {
                commonRoles.IntersectWith(participant.Roles);
            }
            else
            {
                commonRoles.Clear();
                break;
            }
        }

        BannerState.SetActiveRoles(currentUserId, commonRoles.ToList());
    }

    /// <summary>
    /// A helper method that explicitly updates the global banner state based on the currently selected conversation.
    /// </summary>
    private void UpdateBannerForCurrentChat()
    {
        UpdateBannerForParticipants(SelectedConversation?.ParticipantIds);
    }

    /// <summary>
    /// Transitions the UI into 'New Chat' mode, clearing the active conversation selection.
    /// </summary>
    private void OnStartNewChat()
    {
        SelectedConversation = null;
        IsNewChatMode = true;
        IsAddingParticipants = false;
        NewChatSelectedUsers.Clear();
        if (currentUserId != null) BannerState.ClearActiveRoles(currentUserId);
    }

    /// <summary>
    /// Toggles the visibility of the conversation details pane.
    /// </summary>
    private void ToggleDetails()
    {
        IsDetailsOpen = !IsDetailsOpen;
    }

    /// <summary>
    /// Prepares the UI to add a new user to the currently active conversation, essentially starting a 'New Chat'.
    /// </summary>
    private void AddUserToCurrentChat()
    {
        IsDetailsOpen = false;

        if (SelectedConversation == null) return;

        IsNewChatMode = true;
        IsAddingParticipants = true;
        NewChatSelectedUsers.Clear();
        foreach (var p in SelectedConversation.ParticipantIds.Where(id => id != currentUserId))
        {
            NewChatSelectedUsers.Add(p);
        }
        SelectedConversation = null;
        UpdateBannerForParticipants(NewChatSelectedUsers);
    }

    /// <summary>
    /// Sends a request to the SignalR hub for the current user to leave the specified conversation.
    /// </summary>
    /// <param name="conversationId">The ID of the conversation to leave.</param>
    private async Task HandleLeaveChat(int conversationId)
    {
        if (_hubConnection != null && _hubConnection.State == HubConnectionState.Connected)
        {
            // Optimistically update the UI to instantly remove the conversation
            var conv = Conversations.FirstOrDefault(c => c.ConversationId == conversationId);
            if (conv != null)
            {
                Conversations.Remove(conv);
                if (SelectedConversation?.ConversationId == conversationId)
                {
                    SelectedConversation = null;
                    UpdateBannerForCurrentChat();
                }
                Conversations = Conversations.ToList(); // Force Blazor to detect array change
                StateHasChanged();
            }

            await _hubConnection.SendAsync("LeaveConversation", conversationId);
            IsDetailsOpen = false;
        }
    }

    /// <summary>
    /// Toggles a user's selection status when creating a new chat.
    /// </summary>
    /// <param name="userId">The UserID to toggle.</param>
    private void OnToggleNewChatUser(string userId)
    {
        if (NewChatSelectedUsers.Contains(userId)) NewChatSelectedUsers.Remove(userId);
        else NewChatSelectedUsers.Add(userId);

        UpdateBannerForParticipants(NewChatSelectedUsers);
    }

    // Updated Send logic to accept message string
    /// <summary>
    /// Handles sending a message in an existing active conversation.
    /// </summary>
    /// <param name="message">The text message to send.</param>
    private async Task HandleSend(string message)
    {
        await SendMessageInternal(message, false);
    }

    /// <summary>
    /// Handles sending the first message to initiate a brand new conversation.
    /// </summary>
    /// <param name="message">The text message to send.</param>
    private async Task OnStartChat(string message)
    {
        await SendMessageInternal(message, true);
    }

    /// <summary>
    /// Internal method to dispatch a new message via SignalR.
    /// </summary>
    /// <param name="message">The message content.</param>
    /// <param name="isNewChat">True if this message establishes a new conversation.</param>
    private async Task SendMessageInternal(string message, bool isNewChat)
    {
        if (!string.IsNullOrWhiteSpace(message) && currentUserId != null)
        {
            List<string>? participants = null;
            int? conversationId = null;

            if (isNewChat)
            {
                participants = NewChatSelectedUsers.ToList();
            }
            else if (SelectedConversation != null)
            {
                conversationId = SelectedConversation.ConversationId;
            }
            else return;

            if (_hubConnection != null && _hubConnection.State == HubConnectionState.Connected)
            {
                var returnedConvId = await _hubConnection.InvokeAsync<int>("SendMessage", conversationId, participants, message, null);

                if (isNewChat)
                {
                    await Task.Delay(100);
                    SelectedConversation = Conversations.FirstOrDefault(c => c.ConversationId == returnedConvId);
                    IsNewChatMode = false;
                    UpdateBannerForCurrentChat();
                }
            }

            // Scroll to bottom immediately upon sending
            await Task.Delay(50);
            await JSRuntime.InvokeVoidAsync("scrollToBottom", "chatScrollView");
        }
    }

    /// <summary>
    /// Handles file uploads from the chat input, validating extensions and uploading via SignalR.
    /// </summary>
    /// <param name="e">Event arguments containing the selected file.</param>
    private async Task OnFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file != null && currentUserId != null)
        {
            var extension = Path.GetExtension(file.Name).ToLowerInvariant();
            if (!_allowedExtensions.Contains(extension))
            {
                ShowNotification("System", $"File type {extension} is not allowed for security reasons.");
                return;
            }

            var uploadPath = Path.Combine("wwwroot", "uploads");
            if (!Directory.Exists(uploadPath)) Directory.CreateDirectory(uploadPath);
            var fileName = $"{Guid.NewGuid()}{extension}";
            var filePath = Path.Combine(uploadPath, fileName);
            await using var fs = new FileStream(filePath, FileMode.Create);
            await file.OpenReadStream(10 * 1024 * 1024).CopyToAsync(fs);
            var attachmentUrl = $"/uploads/{fileName}";

            List<string>? participants = null;
            int? conversationId = null;

            if (SelectedConversation != null)
            {
                conversationId = SelectedConversation.ConversationId;
            }
            else if (IsNewChatMode)
            {
                participants = NewChatSelectedUsers.ToList();
            }

            if (participants != null || conversationId != null)
            {
                if (_hubConnection != null && _hubConnection.State == HubConnectionState.Connected)
                {
                    var returnedConvId = await _hubConnection.InvokeAsync<int>("SendMessage", conversationId, participants, $"Sent attachment: {file.Name}", attachmentUrl);
                    if (IsNewChatMode)
                    {
                        await Task.Delay(100);
                        SelectedConversation = Conversations.FirstOrDefault(c => c.ConversationId == returnedConvId);
                        UpdateBannerForCurrentChat();
                    }
                }
            }

            if (IsNewChatMode) IsNewChatMode = false;
        }
    }

    // Reaction Actions
    /// <summary>
    /// Toggles a specific emoji reaction on a specific message.
    /// </summary>
    /// <param name="args">A tuple containing the ChatMessage and the emoji string.</param>
    private async Task HandleToggleReaction((ChatMessage msg, string emoji) args)
    {
        if (args.msg.Reactions == null)
        {
            args.msg.Reactions = new List<MessageReactionDto>();
        }

        var existing = args.msg.Reactions.FirstOrDefault(r => r.Emoji == args.emoji && r.UserId == currentUserId);
        if (existing != null)
        {
            await HandleRemoveReaction(args.msg, args.emoji);
        }
        else
        {
            await HandleAddReaction(args.msg, args.emoji);
        }
    }

    /// <summary>
    /// Sends a SignalR request to add a reaction to a message.
    /// </summary>
    /// <param name="msg">The target ChatMessage.</param>
    /// <param name="emoji">The emoji string character.</param>
    private async Task HandleAddReaction(ChatMessage msg, string emoji)
    {
        if (_hubConnection != null && _hubConnection.State == HubConnectionState.Connected)
        {
            await _hubConnection.SendAsync("AddReaction", msg.Id, emoji);
        }
    }

    /// <summary>
    /// Sends a SignalR request to remove a reaction from a message.
    /// </summary>
    /// <param name="msg">The target ChatMessage.</param>
    /// <param name="emoji">The emoji string character.</param>
    private async Task HandleRemoveReaction(ChatMessage msg, string emoji)
    {
        if (_hubConnection != null && _hubConnection.State == HubConnectionState.Connected)
        {
            await _hubConnection.SendAsync("RemoveReaction", msg.Id, emoji);
        }
    }

    private ActiveChatView? activeChatView;

    /// <summary>
    /// Sets the provided message as the active 'Reply' context in the UI.
    /// </summary>
    /// <param name="msg">The message being replied to.</param>
    private async Task HandleReply(ChatMessage msg)
    {
        if (activeChatView != null)
        {
            await activeChatView.SetReplyMessageAsync(msg);
        }
    }

    // UI Helpers for Edit/Delete
    /// <summary>
    /// Enables inline edit mode for a specific chat message.
    /// </summary>
    /// <param name="msg">The message to edit.</param>
    private void StartEdit(ChatMessage msg)
    {
        msg.IsEditing = true;
        msg.EditBuffer = msg.Message;
    }

    /// <summary>
    /// Cancels the inline edit mode for a message, discarding local changes.
    /// </summary>
    /// <param name="msg">The message being edited.</param>
    private void CancelEdit(ChatMessage msg)
    {
        msg.IsEditing = false;
    }

    /// <summary>
    /// Saves the modified message content by sending the update via SignalR.
    /// </summary>
    /// <param name="msg">The edited message.</param>
    private async Task SaveEdit(ChatMessage msg)
    {
        if (msg.EditBuffer == msg.Message)
        {
            msg.IsEditing = false;
            return;
        }

        if (_hubConnection != null && _hubConnection.State == HubConnectionState.Connected)
        {
            await _hubConnection.SendAsync("EditMessage", msg.Id, msg.EditBuffer);
        }

        msg.IsEditing = false;
    }

    /// <summary>
    /// Opens the delete confirmation modal for a specific message.
    /// </summary>
    /// <param name="msg">The message to be deleted.</param>
    private void DeleteMessage(ChatMessage msg)
    {
        MessageToDelete = msg;
        IsDeleteConfirmOpen = true;
    }

    /// <summary>
    /// Closes the delete confirmation modal without deleting the message.
    /// </summary>
    private void CancelDelete()
    {
        IsDeleteConfirmOpen = false;
        MessageToDelete = null;
    }

    /// <summary>
    /// Confirms the deletion of a message, sending the command via SignalR.
    /// </summary>
    private async Task ConfirmDelete()
    {
        if (MessageToDelete != null)
        {
            if (_hubConnection != null && _hubConnection.State == HubConnectionState.Connected)
            {
                await _hubConnection.SendAsync("DeleteMessage", MessageToDelete.Id);
            }
            CancelDelete();
        }
    }
}
